%{%(multiRegionSolidBoundaries/%(0%)/BoundaryType%)
%:constraint
%[0/_boundary_constraint%]
%:default
    %(0%)
    {
        type        calculated;
        value       $internalField;
    }
%}

%}

    // Derived from p_rgh at fluid-solid interface
    defaultFaces
    {
        type        calculated;
        value       $internalField;
    }
}

