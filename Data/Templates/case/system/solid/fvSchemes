%{%(solver/SolverName%)
%:chtMultiRegionSimpleFoam chtMultiRegionFoam
%{%(multiRegionSolidNames%)
%[_header%]
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system/%(multiRegionSolidNames/%(0%)%)";
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

ddtSchemes
{
    default         steadyState;
}

gradSchemes
{
    default         Gauss linear;
}

divSchemes
{
    default         none;
}

laplacianSchemes
{
    default         Gauss linear corrected;
}

interpolationSchemes
{
    default         linear;
}

snGradSchemes
{
    default         corrected;
}

